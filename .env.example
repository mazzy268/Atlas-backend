# ── Database ──────────────────────────────────────────────
# Supabase: Settings → Database → Connection string (Transaction mode)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/atlas

# ── AI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini          # or gpt-4o for higher quality

# ── Data APIs ─────────────────────────────────────────────
# EPC: https://epc.opendatacommunities.org/  (free registration)
EPC_API_KEY=your-epc-api-key
EPC_API_EMAIL=your@email.com

# OS Places (optional — improves address resolution)
OS_PLACES_API_KEY=your-os-key

# ── App ───────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=86400           # 24h — how long to cache property reports
